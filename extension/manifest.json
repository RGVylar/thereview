{
  "manifest_version": 3,
  "name": "The Review Sync",
  "version": "0.2.0",
  "description": "Sincroniza la reproducción de vídeos de TikTok y Twitter/X entre participantes de una sesión de The Review.",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": [
    "*://*.tiktok.com/*",
    "*://*.twitter.com/*",
    "*://twitter.com/*",
    "*://*.x.com/*",
    "*://*.youtube.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://memes.mugrelore.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tiktok.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://x.com/*",
        "*://*.youtube.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "https://memes.mugrelore.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.tiktok.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://x.com/*"
      ],
      "js": ["video-sync.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
  ,
  "web_accessible_resources": [
    {
      "resources": ["page-inject.js", "video-sync.js"],
      "matches": ["*://*/*"]
    }
  ]
}
