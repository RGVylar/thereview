{
  "manifest_version": 3,
  "name": "The Review Sync (prototype)",
  "version": "0.1.0",
  "description": "Prototype extension: responds to page ping so the web app can detect installation.",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": [
    "*://*.tiktok.com/*",
    "*://*.twitter.com/*",
    "*://twitter.com/*",
    "*://*.x.com/*",
    "*://*.youtube.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://192.168.1.178/*",
    "https://192.168.1.178/*",
    "http://192.168.1.178:5173/*",
    "http://192.168.1.178:3000/*",
    "http://192.168.1.178:8080/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tiktok.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://x.com/*",
        "*://*.youtube.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://192.168.1.178/*",
        "https://192.168.1.178/*",
        "http://192.168.1.178:5173/*",
        "http://192.168.1.178:3000/*",
        "http://192.168.1.178:8080/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
  ,
  "web_accessible_resources": [
    {
      "resources": ["page-inject.js"],
      "matches": ["*://*/*"]
    }
  ]
}
